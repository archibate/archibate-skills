{
  "description": "Block heredoc usage when piping to python/bash; redirect to Write tool + temp file workflow",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/no-heredoc.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
