{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash",
      "Read",
      "Skill",
      "Glob",
      "Grep",
      "Write(/*)",
      "Edit(/*)",
      "mcp__web-search-prime__webSearchPrime",
      "mcp__web-reader__webReader",
      "mcp__zread__get_repo_structure",
      "mcp__zread__read_file",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__claude_ai_Gmail__gmail_read_message",
      "mcp__grep__searchGitHub",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:docs.z.ai)",
      "Write(//tmp/**)",
      "Edit(//tmp/**)"
    ],
    "ask": [
      "Read(*.env)",
      "Bash(*sudo *)",
      "Bash(*rm -rf /*)",
      "Bash(*rm -rf ~*)",
      "Bash(*chmod *-R*)",
      "Bash(*chown *-R*)",
      "Bash(*git commit *--amend*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opusplan",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/ubuntu/archibate-skills/hooks/no-heredoc.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/ubuntu/archibate-skills/hooks/question-readonly-hint.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/ubuntu/archibate-skills/hooks/link-venv.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | xargs -n1 basename | sort -V | tail -1); exec \"/usr/bin/bun\" \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins/cache/claude-hud/claude-hud/${plugin_dir}/src/index.ts\"'"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": false,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "voiceEnabled": true,
  "autoMemoryEnabled": true
}
